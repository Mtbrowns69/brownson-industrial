  <style>
    :root{
      --navy:#091b38;
      --navy2:#102a52;
      --orange:#f57c00;
      --orange2:#ff9f43;
      --light:#f3f6fb;
      --white:#ffffff;
      --text:#162846;
      --muted:#5f6f87;
      --line:#dce5f2;
      --shadow:0 18px 40px rgba(9,27,56,.12);
      --radius:24px;
      --max:1200px;
    }

    *{margin:0;padding:0;box-sizing:border-box;font-family:Inter,sans-serif;}
    body{background:var(--light);color:var(--text);line-height:1.7;}
    img{max-width:100%;display:block;}
    .container{max-width:var(--max);margin:auto;padding:0 24px;}

    .hero{
      min-height:72vh;display:flex;align-items:center;position:relative;
      background:
        linear-gradient(rgba(9,27,56,.82), rgba(9,27,56,.88)),
        url('https://images.unsplash.com/photo-1565008447742-97f6f38c985c?q=80&w=1800&auto=format&fit=crop');
      background-size:cover;background-position:center;color:#fff;overflow:hidden;
    }

    .hero::before{
      content:"";position:absolute;width:300px;height:300px;border-radius:50%;
      background:rgba(245,124,0,.18);top:50px;right:80px;filter:blur(60px);
    }

    .hero-content{position:relative;z-index:2;padding:90px 0 80px;max-width:850px;}
    .eyebrow{
      display:inline-block;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);
      color:#fff;padding:10px 16px;border-radius:999px;font-size:12px;font-weight:800;
      letter-spacing:.8px;text-transform:uppercase;margin-bottom:22px;
    }

    .hero h1{font-size:60px;line-height:1.02;font-weight:900;margin-bottom:18px;}
    .hero p{font-size:19px;color:#edf3ff;max-width:760px;}

    .top-bar{
      background:var(--navy);color:#fff;padding:16px 24px;display:flex;justify-content:center;
      gap:30px;flex-wrap:wrap;font-weight:700;font-size:14px;
    }

    section{padding:80px 0;}
    .section-title{font-size:42px;line-height:1.08;font-weight:900;margin-bottom:16px;}
    .section-sub{color:var(--muted);font-size:17px;max-width:820px;margin-bottom:36px;}
    .grid-2{display:grid;grid-template-columns:1.1fr .9fr;gap:34px;align-items:center;}

    .card{
      background:var(--white);border-radius:var(--radius);padding:32px;box-shadow:var(--shadow);
      border:1px solid rgba(9,27,56,.06);
    }

    .card h3{font-size:26px;margin-bottom:16px;}
    .card p{color:var(--muted);font-size:16px;margin-bottom:14px;}
    .image-box img{width:100%;height:100%;min-height:420px;object-fit:cover;border-radius:24px;box-shadow:0 18px 40px rgba(0,0,0,.12);}

    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:26px;}
    .stat{
      background:linear-gradient(135deg,var(--navy),var(--navy2));color:#fff;border-radius:22px;
      padding:28px 24px;box-shadow:0 16px 34px rgba(9,27,56,.16);
    }
    .stat h4{font-size:38px;margin-bottom:10px;}
    .stat p{color:#edf3ff;font-size:15px;line-height:1.8;}

    .services{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
    .service{
      background:#fff;border:1px solid var(--line);border-radius:22px;padding:26px;box-shadow:0 12px 28px rgba(0,0,0,.05);
    }

    .icon{
      width:54px;height:54px;border-radius:16px;background:linear-gradient(135deg,var(--orange),var(--orange2));
      display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;margin-bottom:16px;
      box-shadow:0 10px 24px rgba(245,124,0,.25);
    }

    .service h3{font-size:21px;margin-bottom:12px;}
    .service p{color:var(--muted);font-size:15px;line-height:1.85;}

    .highlight{
      background:
        linear-gradient(rgba(9,27,56,.94), rgba(16,42,82,.94)),
        url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1800&auto=format&fit=crop');
      background-size:cover;background-position:center;color:#fff;border-radius:30px;padding:50px;box-shadow:0 24px 54px rgba(0,0,0,.16);
    }

    .highlight .section-title,.highlight p{color:#fff;}
    .bullet-list{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:24px;}
    .bullet{
      background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:20px;
    }
    .bullet h4{font-size:18px;margin-bottom:10px;}
    .bullet p{color:#edf3ff;font-size:15px;line-height:1.8;}

    .cta{
      text-align:center;background:linear-gradient(135deg,#fff,#f7fbff);border-radius:30px;padding:55px 28px;
      box-shadow:var(--shadow);border:1px solid rgba(9,27,56,.06);
    }
    .cta h2{font-size:42px;margin-bottom:16px;}
    .cta p{color:var(--muted);font-size:18px;max-width:760px;margin:0 auto 26px;}
    .btn{
      display:inline-block;padding:16px 28px;border-radius:14px;background:var(--orange);color:#fff;font-weight:800;
      text-decoration:none;box-shadow:0 12px 28px rgba(245,124,0,.25);transition:.25s ease;
    }
    .btn:hover{transform:translateY(-2px);}

    footer{
      background:#071427;color:#c7d2e4;text-align:center;padding:30px 20px;font-size:14px;line-height:1.9;margin-top:60px;
    }

    @media (max-width:1050px){
      .grid-2,.services,.stats,.bullet-list{grid-template-columns:1fr 1fr;}
      .hero h1{font-size:48px;}
    }

    @media (max-width:760px){
      .grid-2,.services,.stats,.bullet-list{grid-template-columns:1fr;}
      .hero{min-height:auto;}
      .hero-content{padding:80px 0 70px;}
      .hero h1{font-size:38px;}
      .section-title,.cta h2{font-size:32px;}
      .highlight,.card,.cta{padding:26px;}
    }
  </style>
</head>
