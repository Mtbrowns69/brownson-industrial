<section class="reviews">
  <h2 style="text-align:center;margin-bottom:20px;">Client Reviews</h2>

  <div id="reviewList" class="review-grid"></div>

  <h3 style="margin-top:40px;">Leave a Review</h3>

  <form id="reviewForm">
    <input type="text" id="name" placeholder="Your Name" required>
    
    <select id="rating">
      <option value="5">★★★★★ (5)</option>
      <option value="4">★★★★ (4)</option>
      <option value="3">★★★ (3)</option>
      <option value="2">★★ (2)</option>
      <option value="1">★ (1)</option>
    </select>

    <textarea id="comment" placeholder="Your Review" required></textarea>

    <button type="submit">Submit Review</button>
  </form>
</section>
